# .env.example — copy to .env and fill in your credentials
# ── vCenter ──────────────────────────────────────────────
VCENTER_HOST=vcenter.local
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=changeme
VCENTER_PORT=443
VCENTER_SSL_VERIFY=false

# ── Aruba Central ─────────────────────────────────────────
ARUBA_CENTRAL_BASE_URL=https://apigw-prod2.central.arubanetworks.com
ARUBA_CLIENT_ID=your_client_id
ARUBA_CLIENT_SECRET=your_client_secret
ARUBA_CUSTOMER_ID=your_customer_id
ARUBA_ACCESS_TOKEN=your_access_token   # or use OAuth flow

# ── HPE Alletra 6000 / Nimble Storage ────────────────────
# Uses Nimble REST API v1 — default port 5392
ALLETRA_HOST=alletra6k.local
ALLETRA_USER=admin
ALLETRA_PASSWORD=changeme
ALLETRA_PORT=5392

# ── Veeam Backup & Replication ────────────────────────────
VEEAM_HOST=veeam.local
VEEAM_USER=administrator
VEEAM_PASSWORD=changeme
VEEAM_PORT=9419

# ── App ───────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
LOG_LEVEL=INFO

# ── Alerting ──────────────────────────────────────────────
WEBHOOK_URL=                          # Teams/Slack/generic incoming webhook URL
WEBHOOK_FORMAT=teams                  # teams | slack | generic
ALERT_INTERVAL_SECONDS=300            # check every 5 minutes

# vCenter thresholds
ALERT_VCENTER_IDLE_VMS=1
ALERT_VCENTER_OVERSIZED_VMS=5
ALERT_VCENTER_CLUSTER_CPU_LOW_PCT=30.0

# Aruba thresholds
ALERT_ARUBA_UNUSED_PORT_PCT=30.0

# Alletra thresholds
ALERT_ALLETRA_UTIL_HIGH_PCT=80.0
ALERT_ALLETRA_UTIL_LOW_PCT=20.0
ALERT_ALLETRA_EFFICIENCY_MIN=2.0

# Veeam thresholds
ALERT_VEEAM_FAILED_JOBS=1
ALERT_VEEAM_UNPROTECTED_VMS=1
ALERT_VEEAM_REPO_UTIL_PCT=80.0

# ── HPE iLO / Redfish (iLO 5 / 6, Gen10+) ────────────
# Comma-separated list of iLO hostnames or IPs.
# Leave blank to disable the connector entirely.
ILO_HOSTS=ilo1.lab.local,ilo2.lab.local
ILO_USER=Administrator
ILO_PASSWORD=changeme
ILO_PORT=443
ILO_SSL_VERIFY=false

# iLO alert thresholds
ALERT_ILO_POWER_CAP_PCT=90.0     # fire when host power > X% of configured cap
ALERT_ILO_ERROR_COUNT=1          # fire when total IML errors >= this

# ── Historical snapshots ──────────────────────────────
SNAPSHOT_INTERVAL_SECONDS=900     # collect every 15 minutes
SNAPSHOT_RETENTION_DAYS=30        # keep 30 days of history
DB_PATH=glassplane.db             # SQLite file path

# ── Claude AI (Insights) ─────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Auth ──────────────────────────────────────────────────
# Leave API_KEY blank to disable auth entirely (useful for localhost-only installs).
# Set a strong random value for any network-accessible deployment.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Comma-separated allowed CORS origins.  Use * to allow all (default).
# For LAN/browser access set this to your frontend origin, e.g.:
#   ALLOWED_ORIGINS=http://192.168.1.100:5173,http://localhost:5173
ALLOWED_ORIGINS=*
